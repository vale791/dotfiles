# PROGRAMS TO EXECUTE

# nitrogen for wallpaper
#exec_always --no-startup-id nitrogen --restore

# pywal handles that (i think)

# picom because it doesn't get started with gdm login
exec_always --no-startup-id picom -b &

# polybar
exec_always --no-startup-id ~/.config/polybar/launch.sh

# vicinae
exec_always --no-startup-id vicinae server &

# disable x11 bell
exec --no-startup-id xset -b 0

# make it possible to switch languages
# with alt shift
exec_always --no-startup-id setxkbmap -layout "us,il" -option "grp:alt_shift_toggle"

# BINDS
# setting $mod to windows key
set $mod Mod4

# screenshot of whole screen
bindsym Print exec --no-startup-id scrot '%Y-%m-%d-%H%M%S.png' -e 'mv $f ~/Pictures/'

# of selected region
bindsym Print+shift exec --no-startup-id scrot -s '%Y-%m-%d-%H%M%S.png' -e 'mv $f ~/Pictures/'

# set to hdmi-only (turn off laptop screen)
bindsym $mod+h exec xrandr --output eDP-1 --off --output HDMI-1 --primary --auto


# winkey+shift+e to exit
bindsym $mod+shift+e exit

# toggle floating
bindsym $mod+shift+space floating toggle

# open terminal
bindsym $mod+q exec kitty

# open app picker (rofi)
bindsym $mod+space exec vicinae toggle

# kill focused window
bindsym $mod+shift+q kill

# fullscreen for current window
bindsym $mod+f fullscreen toggle

# reload config file
bindsym $mod+r reload

# WINDOWS

# set floating modifier to mod
floating_modifier $mod

tiling_drag modifier titlebar

default_border pixel 2
default_floating_border pixel 2

# gaps
gaps inner 9
gaps outer -1
gaps bottom 26
gaps top 0

# WORKSPACES
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6

# switch window to workspace
bindsym $mod+shift+1 move container to workspace number $ws1
bindsym $mod+shift+2 move container to workspace number $ws2
bindsym $mod+shift+3 move container to workspace number $ws3
bindsym $mod+shift+4 move container to workspace number $ws4
bindsym $mod+shift+5 move container to workspace number $ws5
bindsym $mod+shift+6 move container to workspace number $ws6

